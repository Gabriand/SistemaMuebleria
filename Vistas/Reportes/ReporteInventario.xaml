<Window x:Class="MuebleriaPIS.Vistas.Reportes.ReporteInventario"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
        xmlns:local="clr-namespace:MuebleriaPIS.Vistas.Reportes"
        mc:Ignorable="d" 
        Title="Reporte Inventario" Height="200" Width="400">

    <Grid>
        <TextBlock Text="Se ha generado su reporte y se ha guardado en la ruta especificada."
                   VerticalAlignment="Center" HorizontalAlignment="Center"
                   TextWrapping="Wrap" Margin="20"/>
        <Button Content="Aceptar" Width="100" Height="30" VerticalAlignment="Bottom" HorizontalAlignment="Center" Margin="0,0,0,20" Click="Aceptar_Click"/>
    </Grid>
</Window>
